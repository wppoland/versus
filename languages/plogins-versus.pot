#: src/Admin/Settings.php:84
msgid "Versus"
msgstr ""

#: src/Admin/Settings.php:127
msgid "<strong>Versus</strong> lets shoppers line products up side by side and pick with confidence. Turn the comparison on, choose where the <em>Compare</em> button appears, and decide which details fill the comparison table. Hover or focus the <span aria-hidden=\"true\">?</span> next to any option for a quick explanation."
msgstr ""

#: src/Admin/Settings.php:136
msgid "General"
msgstr ""

#: src/Admin/Settings.php:141
msgid "Enable comparison"
msgstr ""

#: src/Admin/Settings.php:142
msgid "The master switch. When off, no compare buttons, account tab, or table are shown anywhere on the storefront, your other settings here are kept for when you turn it back on."
msgstr ""

#: src/Admin/Settings.php:153
msgid "Show the compare button and enable the comparison table."
msgstr ""

#: src/Admin/Settings.php:159
msgid "Maximum products"
msgstr ""

#: src/Admin/Settings.php:160
msgid "The cap on how many products fit in one comparison. When a shopper adds one more than this, the oldest item drops off automatically so the table never gets unreadably wide. Two to six works best on most themes."
msgstr ""

#: src/Admin/Settings.php:172
msgid "How many products a shopper can compare at once (2–6)."
msgstr ""

#: src/Admin/Settings.php:178
msgid "Placement & access"
msgstr ""

#: src/Admin/Settings.php:182
msgid "Shop & archive loops"
msgstr ""

#: src/Admin/Settings.php:182
msgid "Show the compare button under each product in loops."
msgstr ""

#: src/Admin/Settings.php:182
msgid "Adds a Compare button beneath every product on the shop, category, tag, and search results pages, so shoppers can build a comparison while they browse."
msgstr ""

#: src/Admin/Settings.php:183
msgid "Single product page"
msgstr ""

#: src/Admin/Settings.php:183
msgid "Show the compare button on the single product page."
msgstr ""

#: src/Admin/Settings.php:183
msgid "Adds a Compare button to each individual product page, near the add-to-cart area."
msgstr ""

#: src/Admin/Settings.php:184
msgid "Allow guests"
msgstr ""

#: src/Admin/Settings.php:184
msgid "Let logged-out visitors build a comparison (stored per browser)."
msgstr ""

#: src/Admin/Settings.php:184
msgid "When on, visitors who are not signed in can still compare; their selection is remembered in their own browser for six months. When off, clicking Compare sends them to log in first."
msgstr ""

#: src/Admin/Settings.php:185
msgid "Account menu"
msgstr ""

#: src/Admin/Settings.php:185
msgid "Add a \"Compare\" tab to the My Account menu for logged-in customers."
msgstr ""

#: src/Admin/Settings.php:185
msgid "Adds a Compare tab inside My Account so signed-in customers can return to their saved comparison at any time. If you change this, save and then re-save Permalinks under Settings → Permalinks once."
msgstr ""

#: src/Admin/Settings.php:190
msgid "Comparison table"
msgstr ""

#: src/Admin/Settings.php:192
msgid "Choose which standard fields appear as rows. Rows that differ between products can be highlighted."
msgstr ""

#: src/Admin/Settings.php:197
#: src/Service/VersusService.php:136
msgid "Price"
msgstr ""

#: src/Admin/Settings.php:197
msgid "Adds a Price row showing each product’s current price (including any sale price)."
msgstr ""

#: src/Admin/Settings.php:198
#: src/Service/VersusService.php:137
msgid "SKU"
msgstr ""

#: src/Admin/Settings.php:198
msgid "Adds a SKU row, useful for shops where customers reference part or model numbers."
msgstr ""

#: src/Admin/Settings.php:199
#: src/Service/VersusService.php:138
msgid "Availability"
msgstr ""

#: src/Admin/Settings.php:199
msgid "Adds a stock-status row (In stock, Out of stock, On backorder) so shoppers can rule out unavailable options."
msgstr ""

#: src/Admin/Settings.php:200
msgid "Short description"
msgstr ""

#: src/Admin/Settings.php:200
msgid "Adds a row with each product’s short description for an at-a-glance summary."
msgstr ""

#: src/Admin/Settings.php:201
msgid "Product attributes"
msgstr ""

#: src/Admin/Settings.php:201
msgid "Add a row for each product attribute (colour, size, material, …)."
msgstr ""

#: src/Admin/Settings.php:201
msgid "Adds one row per product attribute (such as colour, size, or material). Only attributes that at least one of the compared products defines are shown."
msgstr ""

#: src/Admin/Settings.php:202
msgid "Highlight differences"
msgstr ""

#: src/Admin/Settings.php:202
msgid "Visually highlight rows whose values differ between products."
msgstr ""

#: src/Admin/Settings.php:202
msgid "Tints any row where the products’ values are not identical, so the things that set them apart jump out immediately."
msgstr ""

#: src/Admin/Settings.php:203
msgid "Default to differences only"
msgstr ""

#: src/Admin/Settings.php:203
msgid "Tick the \"show only differences\" toggle by default."
msgstr ""

#: src/Admin/Settings.php:203
msgid "Pre-ticks the “Show only differences” toggle on the comparison page, hiding rows that are the same. Shoppers can still untick it to see everything."
msgstr ""

#: src/Admin/Settings.php:204
msgid "Product image"
msgstr ""

#: src/Admin/Settings.php:204
msgid "Show the product image in each column header."
msgstr ""

#: src/Admin/Settings.php:204
msgid "Shows each product’s thumbnail at the top of its column. Space is reserved for the image so the table never jumps as pictures load."
msgstr ""

#: src/Admin/Settings.php:205
msgid "Add to cart"
msgstr ""

#: src/Admin/Settings.php:205
msgid "Show an add-to-cart button in each column header."
msgstr ""

#: src/Admin/Settings.php:205
msgid "Adds an Add to cart button under each product so shoppers can buy straight from the comparison once they have decided."
msgstr ""

#: src/Admin/Settings.php:206
msgid "Remove button"
msgstr ""

#: src/Admin/Settings.php:206
msgid "Show a remove button in each column header."
msgstr ""

#: src/Admin/Settings.php:206
msgid "Lets shoppers drop a single product from the comparison without clearing the whole list."
msgstr ""

#: src/Admin/Settings.php:211
msgid "Labels &amp; text"
msgstr ""

#: src/Admin/Settings.php:213
msgid "Customise the front-end strings. Leave a field empty to use the default translation."
msgstr ""

